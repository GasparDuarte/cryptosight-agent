# Copy this file to .env and fill in your keys.

# --- Anthropic (Claude) ---
# Required for the AI agent + chat. Leave the placeholder to run in deterministic mode.
ANTHROPIC_API_KEY=tu_key_aqui
# Cheapest model (good for testing). Also: claude-sonnet-4-5, claude-opus-4-5
ANTHROPIC_MODEL=claude-haiku-4-5

# --- CoinGecko (optional, raises rate limits) ---
COINGECKO_API_KEY=
COINGECKO_PLAN=demo
